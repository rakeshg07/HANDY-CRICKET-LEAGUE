{
  "name": "handy-cricket-league",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "prepare": "npm run build --workspace=shared",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
    "build:vercel": "cd client && npm run build",
    "test": "node scripts/run-tests.mjs",
    "start": "npm run start --workspace=server",
    "start:client": "npm run start --workspace=client",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
